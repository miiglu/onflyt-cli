{
  "name": "onflyt-cli",
  "version": "0.1.3",
  "type": "module",
  "description": "Onflyt CLI - Deploy Node.js and Python APIs to serverless pods. Pay only per use.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miiglu/onflyt-cli.git"
  },
  "main": "dist/index.js",
  "bin": {
    "onflyt": "./bin/cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "esbuild src/index.tsx --bundle --platform=node --outfile=dist/index.js --format=esm --external:react-devtools-core --external:ink --external:react --external:react-dom --external:figlet",
    "start": "node dist/index.js",
    "pack": "npm pack --pack-destination dist"
  },
  "keywords": [
    "cli",
    "deployment",
    "serverless",
    "nodejs",
    "python",
    "api",
    "serverless-pods",
    "typescript",
    "react",
    "ink",
    "cloudflare",
    "cloud",
    "devops",
    "onflyt"
  ],
  "author": "Miiglu",
  "license": "Apache-2.0",
  "dependencies": {
    "@octokit/oauth-methods": "^6.0.2",
    "archiver": "^7.0.1",
    "figlet": "^1.11.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^14.1.0",
    "open": "^11.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.7",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
